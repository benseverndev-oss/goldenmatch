FROM python:3.12-slim@sha256:090ba77e2958f6af52a5341f788b50b032dd4ca28377d2893dcf1ecbdfdfe203
# cache-bust: v1.8.0 (introspective auto-config controller)
WORKDIR /app

# Build deps for `diptest` (Hartigan's dip statistic; v1.8 hard dep — has a
# C++ extension). Removed after pip install to keep the image small.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        gcc \
        g++ \
    && rm -rf /var/lib/apt/lists/*

COPY . .
RUN pip install --no-cache-dir ".[mcp]" \
    && apt-get purge -y build-essential cmake gcc g++ \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*

EXPOSE 8200

CMD ["goldenmatch", "mcp-serve", "--transport", "http", "--port", "8200"]
