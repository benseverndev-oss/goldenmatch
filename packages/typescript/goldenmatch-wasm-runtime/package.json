{
  "name": "goldenmatch-wasm-runtime",
  "version": "0.1.0",
  "description": "Shared opt-in WASM plumbing (byte loader, enable skeleton, backend registry) for the Golden Suite TypeScript packages",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "author": "Ben Severn (https://bensevern.dev)",
  "homepage": "https://github.com/benseverndev-oss/goldenmatch/tree/main/packages/typescript/goldenmatch-wasm-runtime",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benseverndev-oss/goldenmatch.git",
    "directory": "packages/typescript/goldenmatch-wasm-runtime"
  },
  "bugs": {
    "url": "https://github.com/benseverndev-oss/goldenmatch/issues"
  }
}
