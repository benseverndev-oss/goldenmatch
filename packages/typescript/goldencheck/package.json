{
  "name": "goldencheck",
  "version": "0.6.0",
  "description": "Data validation that discovers rules from your data. TypeScript port of the goldencheck Python library.",
  "keywords": [
    "data-validation",
    "data-quality",
    "profiling",
    "csv",
    "goldencheck",
    "drift-detection",
    "schema",
    "edge"
  ],
  "license": "MIT",
  "author": "Ben Severn (https://bensevern.dev)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benseverndev-oss/goldenmatch.git",
    "directory": "packages/typescript/goldencheck"
  },
  "homepage": "https://github.com/benseverndev-oss/goldenmatch/tree/main/packages/typescript/goldencheck",
  "bugs": {
    "url": "https://github.com/benseverndev-oss/goldenmatch/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./core/wasm": {
      "types": "./dist/core/goldencheckWasm.d.ts",
      "import": "./dist/core/goldencheckWasm.js",
      "require": "./dist/core/goldencheckWasm.cjs"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js",
      "require": "./dist/node/index.cjs"
    }
  },
  "bin": {
    "goldencheck-js": "./dist/cli.cjs",
    "goldencheck-mcp": "./dist/node/mcp/server.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "goldencheck-types": "workspace:^"
  },
  "peerDependencies": {
    "nodejs-polars": "*",
    "yaml": "*"
  },
  "peerDependenciesMeta": {
    "nodejs-polars": { "optional": true },
    "yaml": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "nodejs-polars": "^0.25.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
