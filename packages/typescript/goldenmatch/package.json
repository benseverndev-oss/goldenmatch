{
  "name": "goldenmatch",
  "version": "1.1.0",
  "description": "Entity resolution toolkit — deduplicate, match, and create golden records",
  "type": "module",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" },
    "./core": { "types": "./dist/core/index.d.ts", "import": "./dist/core/index.js", "require": "./dist/core/index.cjs" },
    "./core/autoconfig-wasm": { "types": "./dist/core/autoconfigWasm.d.ts", "import": "./dist/core/autoconfigWasm.js", "require": "./dist/core/autoconfigWasm.cjs" },
    "./core/suggest-wasm": { "types": "./dist/core/suggestWasm.d.ts", "import": "./dist/core/suggestWasm.js", "require": "./dist/core/suggestWasm.cjs" },
    "./core/perceptual-wasm": { "types": "./dist/core/perceptualWasm.d.ts", "import": "./dist/core/perceptualWasm.js", "require": "./dist/core/perceptualWasm.cjs" },
    "./node": { "types": "./dist/node/index.d.ts", "import": "./dist/node/index.js", "require": "./dist/node/index.cjs" }
  },
  "bin": { "goldenmatch-js": "./dist/cli.cjs", "goldenmatch-mcp": "./dist/node/mcp/server.cjs" },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist",
    "sync:refdata": "node scripts/sync_ts_refdata.mjs"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "peerDependencies": {
    "yaml": "*",
    "ink": "^5.0.0",
    "react": "^18.0.0",
    "hnswlib-node": "^3.0.0",
    "@huggingface/transformers": "^3.0.0",
    "piscina": "^5.0.0",
    "ink-table": "^3.1.0",
    "ink-select-input": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-gradient": "^3.0.0",
    "better-sqlite3": "^12.11.1"
  },
  "peerDependenciesMeta": {
    "yaml": { "optional": true },
    "ink": { "optional": true },
    "react": { "optional": true },
    "hnswlib-node": { "optional": true },
    "@huggingface/transformers": { "optional": true },
    "piscina": { "optional": true },
    "ink-table": { "optional": true },
    "ink-select-input": { "optional": true },
    "ink-text-input": { "optional": true },
    "ink-spinner": { "optional": true },
    "ink-gradient": { "optional": true },
    "better-sqlite3": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^25.9.4",
    "fast-check": "^4.8.0",
    "goldenmatch-wasm-runtime": "workspace:^",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0",
    "better-sqlite3": "^12.11.1"
  },
  "keywords": [
    "entity-resolution", "deduplication", "record-linkage", "fuzzy-matching",
    "golden-record", "data-quality", "jaro-winkler", "levenshtein",
    "splink", "fellegi-sunter", "pprl", "golden-suite"
  ],
  "license": "MIT",
  "author": "Ben Severn (https://bensevern.dev)",
  "homepage": "https://github.com/benseverndev-oss/goldenmatch/tree/main/packages/typescript/goldenmatch",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benseverndev-oss/goldenmatch.git",
    "directory": "packages/typescript/goldenmatch"
  },
  "bugs": {
    "url": "https://github.com/benseverndev-oss/goldenmatch/issues"
  }
}
