        "entities": [
          { "entity_id": 0, "canonical_name": "Acme Inc", "typ": "org", "surface_names": ["Acme Inc", "Beta"] },
          { "entity_id": 1, "canonical_name": "Product", "typ": "product", "surface_names": ["Product"] }
