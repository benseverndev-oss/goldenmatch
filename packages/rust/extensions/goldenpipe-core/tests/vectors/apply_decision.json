[
  {"comment": "skip filters by name",
   "input": {"decision": {"skip": ["b"], "reason": "x"},
             "remaining": [{"name": "a", "use": "a"}, {"name": "b", "use": "b"}, {"name": "c", "use": "c"}]},
   "expected": {"remaining": [{"name": "a", "use": "a", "config": {}, "on_error": "continue"},
                              {"name": "c", "use": "c", "config": {}, "on_error": "continue"}],
                "router_note": "x"}},
  {"comment": "insert prepends in order, empty reason -> no note",
   "input": {"decision": {"insert": ["x", "y"]},
             "remaining": [{"name": "a", "use": "a"}]},
   "expected": {"remaining": [{"name": "x", "use": "x", "config": {}, "on_error": "continue"},
                              {"name": "y", "use": "y", "config": {}, "on_error": "continue"},
                              {"name": "a", "use": "a", "config": {}, "on_error": "continue"}]}},
  {"comment": "abort empties + prefixes note",
   "input": {"decision": {"abort": true, "reason": "critical"},
             "remaining": [{"name": "a", "use": "a"}]},
   "expected": {"remaining": [], "router_note": "ABORT: critical"}},
  {"comment": "skip + insert combined",
   "input": {"decision": {"skip": ["a"], "insert": ["z"], "reason": "r"},
             "remaining": [{"name": "a", "use": "a"}, {"name": "b", "use": "b"}]},
   "expected": {"remaining": [{"name": "z", "use": "z", "config": {}, "on_error": "continue"},
                              {"name": "b", "use": "b", "config": {}, "on_error": "continue"}],
                "router_note": "r"}},
  {"comment": "empty decision is a no-op (no note)",
   "input": {"decision": {},
             "remaining": [{"name": "a", "use": "a"}, {"name": "b", "use": "b"}]},
   "expected": {"remaining": [{"name": "a", "use": "a", "config": {}, "on_error": "continue"},
                              {"name": "b", "use": "b", "config": {}, "on_error": "continue"}]}}
]
