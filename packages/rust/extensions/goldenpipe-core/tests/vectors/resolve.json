[
  {"comment": "happy 3-stage with auto-prepended load",
   "input": {"config": {"pipeline": "auto", "stages": ["goldencheck.scan", "goldenmatch.dedupe"]},
             "stages": [{"key": "load", "name": "load", "produces": ["df"], "consumes": []},
                        {"key": "goldencheck.scan", "name": "goldencheck.scan", "produces": ["findings"], "consumes": ["df"]},
                        {"key": "goldenmatch.dedupe", "name": "goldenmatch.dedupe", "produces": ["clusters"], "consumes": ["df", "findings"]}]},
   "expected": {"ok": {"stages": [{"name": "load", "use": "load", "config": {}, "on_error": "continue"},
                                  {"name": "goldencheck.scan", "use": "goldencheck.scan", "config": {}, "on_error": "continue"},
                                  {"name": "goldenmatch.dedupe", "use": "goldenmatch.dedupe", "config": {}, "on_error": "continue"}]}}},
  {"comment": "no load stage -> df seeded, single stage",
   "input": {"config": {"pipeline": "auto", "stages": ["s"]},
             "stages": [{"key": "s", "name": "s", "produces": ["out"], "consumes": ["df"]}]},
   "expected": {"ok": {"stages": [{"name": "s", "use": "s", "config": {}, "on_error": "continue"}]}}},
  {"comment": "bare-string vs spec-object entry both work",
   "input": {"config": {"pipeline": "auto", "stages": [{"use": "s"}]},
             "stages": [{"key": "s", "name": "s", "produces": ["out"], "consumes": ["df"]}]},
   "expected": {"ok": {"stages": [{"name": "s", "use": "s", "config": {}, "on_error": "continue"}]}}},
  {"comment": "wiring error lists sorted available",
   "input": {"config": {"pipeline": "auto", "stages": ["s"]},
             "stages": [{"key": "s", "name": "s", "produces": ["out"], "consumes": ["missing"]}]},
   "expected": {"err": {"kind": "wiring", "stage": "s", "missing": "missing", "available": ["df"]}}},
  {"comment": "unknown use",
   "input": {"config": {"pipeline": "auto", "stages": ["nope"]}, "stages": []},
   "expected": {"err": {"kind": "unknown_stage", "use": "nope"}}},
  {"comment": "spec.name overrides info.name",
   "input": {"config": {"pipeline": "auto", "stages": [{"use": "thekey", "name": "alias"}]},
             "stages": [{"key": "thekey", "name": "thekey", "produces": [], "consumes": ["df"]}]},
   "expected": {"ok": {"stages": [{"name": "alias", "use": "thekey", "config": {}, "on_error": "continue"}]}}},
  {"comment": "lookup by key when key != info.name",
   "input": {"config": {"pipeline": "auto", "stages": ["gm.dedupe"]},
             "stages": [{"key": "gm.dedupe", "name": "Dedupe", "produces": [], "consumes": ["df"]}]},
   "expected": {"ok": {"stages": [{"name": "Dedupe", "use": "gm.dedupe", "config": {}, "on_error": "continue"}]}}},
  {"comment": "passthrough config echoed (value equality; order guarded by json.rs test)",
   "input": {"config": {"pipeline": "auto", "stages": [{"use": "s", "config": {"z": 1, "a": 2, "m": 3}}]},
             "stages": [{"key": "s", "name": "s", "produces": [], "consumes": ["df"]}]},
   "expected": {"ok": {"stages": [{"name": "s", "use": "s", "config": {"z": 1, "a": 2, "m": 3}, "on_error": "continue"}]}}},
  {"comment": "empty pipeline, no load -> empty plan",
   "input": {"config": {"pipeline": "auto", "stages": []}, "stages": []},
   "expected": {"ok": {"stages": []}}},
  {"comment": "chained consume+produce",
   "input": {"config": {"pipeline": "auto", "stages": ["a", "b"]},
             "stages": [{"key": "a", "name": "a", "produces": ["out"], "consumes": ["df"]},
                        {"key": "b", "name": "b", "produces": [], "consumes": ["out"]}]},
   "expected": {"ok": {"stages": [{"name": "a", "use": "a", "config": {}, "on_error": "continue"},
                                  {"name": "b", "use": "b", "config": {}, "on_error": "continue"}]}}}
]
